rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile images: Only the owning user can write their own image.
    // Only authenticated users can read profile images.
    // SECURITY FIX: Enforce filename ownership (UID prefix) so users
    // cannot overwrite other users' profile photos.
    match /profile_images/{imageFile} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && imageFile.matches(request.auth.uid + '[.].*')
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Service images: public read (catalog images), admin-only write
    match /services/{imageFile} {
      allow read: if true;
      allow write: if false;
    }

    // Default: deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
